# SoloTrend X Environment Configuration
# This file is used by python-dotenv to configure environment variables

# MT4 REST API configuration
USE_MOCK_MODE=true
MT4_SERVER=localhost
MT4_PORT=443
MT4_LOGIN=0
MT4_PASSWORD=your_mt4_password_here
PORT=5002

# Webhook API configuration
WEBHOOK_API_PORT=5003
TELEGRAM_WEBHOOK_URL=http://localhost:5005/webhook
MOCK_MODE=True
FLASK_DEBUG=True

# Telegram connector configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_BOT_LINK=https://t.me/your_bot_username
TELEGRAM_CHAT_ID=your_telegram_chat_id
TELEGRAM_WEBHOOK_URL=http://localhost:5005/webhook
MT4_API_URL=http://localhost:5002/api
FLASK_PORT=5005
ADMIN_USER_IDS=your_admin_user_id
ALLOWED_USER_IDS=your_admin_user_id,another_user_id