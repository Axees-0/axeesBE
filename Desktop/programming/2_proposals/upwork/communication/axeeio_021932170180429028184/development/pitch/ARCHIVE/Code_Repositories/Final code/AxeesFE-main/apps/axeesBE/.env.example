# Axees Platform Environment Variables Template
# Copy this file to .env and fill in your actual values

# Application
NODE_ENV=development
PORT=3000
API_BASE_URL=http://localhost:3000

# Database
MONGODB_URI=mongodb://localhost:27017/axees-dev
MONGODB_TEST_URI=mongodb://localhost:27017/axees-test

# Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=24h
BCRYPT_ROUNDS=10

# Twilio SMS
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# MessageCentral SMS (Alternative)
MESSAGECENTRAL_API_KEY=your-messagecentral-api-key
MESSAGECENTRAL_BASE_URL=https://api.messagecentral.com

# Stripe Payment
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_SUCCESS_URL=http://localhost:3000/payment-success
STRIPE_CANCEL_URL=http://localhost:3000/payment-cancel

# Firebase Push Notifications
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour-firebase-private-key\n-----END PRIVATE KEY-----"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-specific-password
EMAIL_FROM=noreply@axees.io
EMAIL_FROM_NAME=Axees Platform

# OpenAI (if using AI features)
OPENAI_API_KEY=sk-your-openai-api-key

# Apify (if using web scraping)
APIFY_TOKEN=your-apify-token

# AWS (if using S3 for file storage)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
S3_BUCKET_NAME=axees-uploads

# Redis (if using for caching/sessions)
REDIS_URL=redis://localhost:6379

# Frontend URLs
FRONTEND_URL=http://localhost:3000
ADMIN_FRONTEND_URL=http://localhost:3001

# Platform Configuration
PLATFORM_FEE_PERCENTAGE=5
ESCROW_RELEASE_PERCENTAGE=50
MIN_WITHDRAWAL_AMOUNT=50
MAX_FILE_SIZE=10485760

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# OTP Configuration
OTP_EXPIRES_IN=300
OTP_MAX_ATTEMPTS=5

# Notification Settings
NOTIFICATION_DELAY_MS=120000
PUSH_NOTIFICATION_ENABLED=true
EMAIL_NOTIFICATION_ENABLED=true
SMS_NOTIFICATION_ENABLED=true

# Monitoring (optional)
SENTRY_DSN=your-sentry-dsn
MONITORING_API_KEY=your-monitoring-key

# Development Tools (optional)
NGROK_AUTH_TOKEN=your-ngrok-token